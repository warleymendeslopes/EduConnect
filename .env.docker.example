# Copie para .env (docker compose le .env automaticamente) e ajuste os valores.
# cp .env.docker.example .env

# --- Postgres (servico db) ---
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=appdb

# --- App ---
DATABASE_POOL_MAX=10
# Troque por um segredo forte: `openssl rand -base64 32`
AUTH_SECRET=dev-only-change-me
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Integracoes (opcionais para subir; necessarias para upload e revisao de conteudo)
BLOB_READ_WRITE_TOKEN=
XAI_API_KEY=
